# Vault
VAULT_PATH=./vault

# OpenAI (LangChain extraction + Red Team)
OPENAI_API_KEY=

# Neo4j (match docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password_must_be_changed

# Sync: when true, obsidian_to_neo4j applies Cypher to Neo4j; when false, only writes vault/proposed/
AUTO_COMMIT=false

# Firecrawl (cold start)
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
NYC_DOT_SEED_URLS=https://www.nyc.gov/html/dot/html/about/open-data.shtml

# API
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard dev proxy (Vite)
VITE_API_URL=http://localhost:8000
